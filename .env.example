# OpenAI APIй–°е¶Үз–Ҷ
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Claude APIй–°е¶Үз–Ҷ
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# йҸҲо„Җж№ҙLLMй–°е¶Үз–Ҷй”ӣе қеҪІй–«еӨӣзҙҡ
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama2

# йҸҒзүҲеөҒй–°е¶Үз–Ҷ
DATA_CACHE_DIR=./data/cache
HISTORICAL_DATA_YEARS=5

# жҗҙж—Ӯж•Өй–°е¶Үз–Ҷ
DEBUG=false
LOG_LEVEL=INFO

# йҺ¶жӣЎзҘ«й–°е¶Үз–Ҷ
DEFAULT_INVESTMENT_AMOUNT=10000
RISK_TOLERANCE=moderate  # conservative, moderate, aggressive

# DeepSeek Research Agent (optional; keep blank for mock/testing)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=

# Research dashboard and API deployment
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8001
RESEARCH_API_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,https://dashboard.outlook.xin
RESEARCH_RUNS_DIRECTORY=data/research_runs
